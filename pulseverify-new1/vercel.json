{
  "crons": [
    {
      "path": "/api/cron/nightly",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/monthly-reset",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/provider-briefing",
      "schedule": "*/30 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/webhooks/vapi",
      "destination": "/api/webhooks/vapi"
    },
    {
      "source": "/api/webhooks/ehr",
      "destination": "/api/webhooks/ehr"
    },
    {
      "source": "/api/webhooks/stripe",
      "destination": "/api/webhooks/stripe"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
